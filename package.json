{
  "name": "podcast-alarm-clock",
  "version": "1.0.0",
  "description": "A local alarm clock that plays podcast episodes from RSS feeds through Sonos speakers",
  "main": "index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "test": "jest",
    "build": "cd client && npm run build",
    "setup": "cp -n .env.example .env 2>/dev/null || true; npm install; npm run build",
    "postinstall": "cd client && npm install",
    "prod": "NODE_ENV=production node server/index.js",
    "deploy": "npm run build && pm2 start ecosystem.config.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop podcast-alarm-clock",
    "pm2:restart": "pm2 restart podcast-alarm-clock",
    "pm2:logs": "pm2 logs podcast-alarm-clock",
    "pm2:status": "pm2 status"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "node-cron": "^4.2.1",
    "rss-parser": "^3.13.0",
    "sonos": "^1.14.2",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2"
  }
}
